---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import FooterSection from '../../components/FooterSection.astro';
import { Activity, Search, ShieldAlert, ArrowRight, Bug, FileSearch, Zap, Database } from 'lucide-react';

const lang = 'es';
---

<Layout title="Auditoría de Código & Seguridad | BaseLogic">
  
  <div class="fixed inset-0 bg-grid-pattern z-0 pointer-events-none opacity-30"></div>

  <div class="relative z-10">
    <Navbar lang={lang} translatedPath="/en/services/audit" />
    
    <main class="pt-32 pb-20">
      
      <div class="max-w-7xl mx-auto px-6 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-yellow-500/30 bg-yellow-500/10 text-yellow-500 text-xs font-mono mb-6">
          <Activity class="w-3 h-3" />
          Code Forensics
        </div>
        <h1 class="text-5xl md:text-7xl font-bold mb-6">
          Elimina la <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-300 to-red-500">
            Deuda Técnica.
          </span>
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl leading-relaxed">
          Analizamos la "Caja Negra". Detectamos vulnerabilidades críticas, cuellos de botella en bases de datos y código spaghetti antes de que el sistema colapse en producción.
        </p>
      </div>

      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-start mb-32">
        
        <div class="relative group order-last lg:order-last">
          <div class="absolute -inset-1 bg-gradient-to-r from-yellow-500 to-red-600 rounded-xl blur opacity-20 group-hover:opacity-40 transition duration-1000"></div>
          
          <div class="relative bg-brand-dark border border-brand-border rounded-xl overflow-hidden shadow-2xl">
            <div class="bg-brand-surface border-b border-brand-border px-4 py-2 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
              <div class="text-xs font-mono text-slate-500 ml-2">baselogic-audit · Angular/NestJS target</div>
            </div>

            <div class="p-6 font-mono text-xs md:text-sm overflow-x-auto leading-relaxed">
              <div class="text-slate-300">
                <span class="text-green-400">➜</span> <span class="text-blue-400">~</span> ./baselogic-audit --target=app --stack=angular,nestjs --deep<br><br>
                <span class="text-slate-500">[INFO] SAST + Runtime profiling started...</span><br>
                <span class="text-slate-500">[INFO] Analyzing 1,842 TypeScript files...</span><br>
                <br/>
                <span class="text-red-500 bg-red-500/10 px-1">WARN</span> <span class="text-white">Memory Leak · RxJS Subject sin unsubscribe</span><br>
                <span class="text-slate-400 ml-4">↳ DashboardComponent.ts:88 — ngOnDestroy vacío</span><br>
                <span class="text-slate-400 ml-4">↳ Impacto: heap +120MB tras 2h de sesión</span><br>
                <br/>
                <span class="text-red-500 bg-red-500/10 px-1">WARN</span> <span class="text-white">N+1 Query · Prisma ORM (relaciones en loop)</span><br>
                <span class="text-slate-400 ml-4">↳ AssetService.ts:214 — findMany sin include</span><br>
                <span class="text-slate-400 ml-4">↳ 14,000 queries/req → Latencia: 4.8s</span><br>
                <br/>
                <span class="text-blue-400 bg-blue-500/10 px-1">INFO</span> <span class="text-white">Bottleneck Zone.js · Change Detection global</span><br>
                <span class="text-slate-400 ml-4">↳ 38 componentes sin OnPush strategy</span><br>
                <span class="text-slate-400 ml-4">↳ Recomendación: Migrar a Angular 18 Signals</span><br>
                <br/>
                <span class="text-green-500 bg-green-500/10 px-1">PASS</span> <span class="text-white">TypeScript strict mode · 0 errores de tipo</span><br>
                <br/>
                <span class="text-brand-cyan">Generando Plan de Remediación P1/P2/P3_</span><span class="animate-pulse">█</span>
              </div>
            </div>
          </div>

          <div class="flex gap-4 mt-6 justify-center">
             <div class="bg-brand-surface border border-brand-border px-4 py-2 rounded-lg flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
                <span class="text-xs font-mono text-slate-400">Critical Risks</span>
             </div>
             <div class="bg-brand-surface border border-brand-border px-4 py-2 rounded-lg flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-yellow-500"></div>
                <span class="text-xs font-mono text-slate-400">Performance</span>
             </div>
          </div>
        </div>

        <div>
          <h2 class="text-3xl font-bold mb-2">Diagnóstico de Precisión</h2>
          <p class="text-sm font-mono text-yellow-500 mb-8">Especialistas en Angular · NestJS · TypeScript</p>

          <div class="space-y-8">
            <div class="flex gap-4">
              <div class="mt-1 bg-red-500/10 p-2 rounded-lg h-fit border border-red-500/20">
                <ShieldAlert class="w-5 h-5 text-red-500" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Memory Leaks & RxJS</h3>
                <p class="text-slate-400 text-sm">
                  Detectamos Subjects sin <code class="text-brand-cyan text-xs">unsubscribe</code>, Observables pendientes en <code class="text-brand-cyan text-xs">ngOnDestroy</code> y listeners huérfanos que saturan el heap en sesiones largas de Angular.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="mt-1 bg-yellow-500/10 p-2 rounded-lg h-fit border border-yellow-500/20">
                <Activity class="w-5 h-5 text-yellow-500" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Performance & Prisma ORM</h3>
                <p class="text-slate-400 text-sm">
                  Identificamos consultas N+1 (relaciones cargadas en loop sin <code class="text-brand-cyan text-xs">include</code>), falta de índices en PostgreSQL y cuellos de botella en Zone.js con recomendación de migración a Angular Signals.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="mt-1 bg-brand-blue/10 p-2 rounded-lg h-fit border border-brand-blue/20">
                <FileSearch class="w-5 h-5 text-brand-blue" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Arquitectura & Deuda Técnica</h3>
                <p class="text-slate-400 text-sm">
                  Evaluamos módulos NestJS con acoplamiento alto, falta de separación de capas y ausencia de TypeScript estricto. Si heredaste un proyecto "Frankenstein", entregamos un roadmap de refactorización priorizado.
                </p>
              </div>
            </div>
          </div>

          <div class="mt-10">
            <a href="#contacto" class="inline-flex items-center gap-2 bg-white text-brand-dark px-6 py-3 rounded-xl font-bold hover:bg-slate-200 transition-colors">
              Solicitar Auditoría Express <ArrowRight class="w-4 h-4" />
            </a>
          </div>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-6 border-t border-brand-border pt-20">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold mb-4">Metodología Forense</h2>
            <p class="text-slate-400">No auditamos "a ojo". Usamos herramientas de industria para datos objetivos en aplicaciones TypeScript de producción.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
            <div class="p-6 rounded-xl bg-brand-surface border border-brand-border hover:border-yellow-500/30 transition-colors">
                <Zap class="w-8 h-8 text-slate-400 mb-4" />
                <h3 class="font-bold text-white mb-2">Load Testing (k6)</h3>
                <p class="text-sm text-slate-400">
                    Sometemos tu API NestJS a tráfico simulado (10k usuarios virtuales) para encontrar el punto exacto de quiebre, incluyendo Gateways de WebSocket en tiempo real.
                </p>
            </div>
            
            <div class="p-6 rounded-xl bg-brand-surface border border-brand-border hover:border-yellow-500/30 transition-colors">
                <Bug class="w-8 h-8 text-slate-400 mb-4" />
                <h3 class="font-bold text-white mb-2">Static Analysis (SonarQube)</h3>
                <p class="text-sm text-slate-400">
                    Escaneo de cada línea TypeScript para detectar <code class="text-yellow-400 text-xs">any</code> implícitos, complejidad ciclomática alta, duplicidad y dependencias con vulnerabilidades CVE.
                </p>
            </div>
            
            <div class="p-6 rounded-xl bg-brand-surface border border-brand-border hover:border-yellow-500/30 transition-colors">
                <Database class="w-8 h-8 text-slate-400 mb-4" />
                <h3 class="font-bold text-white mb-2">Plan de Remediación</h3>
                <p class="text-sm text-slate-400">
                    No solo malas noticias. Entregamos un "Roadmap de Arreglos" priorizado por impacto y esfuerzo (P1, P2, P3) con ejemplos de código corregido para cada hallazgo.
                </p>
            </div>
        </div>
      </div>

    </main>

    <FooterSection lang={lang} />
  </div>
</Layout>