---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import FooterSection from '../../components/FooterSection.astro';
import { LayoutTemplate, Users, BarChart3, ArrowRight, ShieldCheck, Zap, Globe, Lock } from 'lucide-react';

const lang = 'es';
---

<Layout title="Desarrollo SaaS & Dashboards | BaseLogic">
  
  <div class="fixed inset-0 bg-grid-pattern z-0 pointer-events-none opacity-30"></div>

  <div class="relative z-10">
    <Navbar lang={lang} translatedPath="/en/services/saas" />
    
    <main class="pt-32 pb-20">
      
      <div class="max-w-7xl mx-auto px-6 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-blue/20 bg-brand-blue/5 text-brand-blue text-xs font-mono mb-6">
          <LayoutTemplate class="w-3 h-3" />
          Enterprise Business OS
        </div>
        <h1 class="text-5xl md:text-7xl font-bold mb-6">
          El Sistema Operativo <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-blue to-brand-cyan">
            de tu Negocio.
          </span>
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl leading-relaxed">
          Deja de gestionar tu empresa con Excel. Desarrollamos plataformas SaaS Multi-tenant, intranets seguras y portales B2B con arquitectura moderna y escalable.
        </p>
      </div>

      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center mb-32">
        
        <div class="relative group order-last lg:order-last">
          <div class="absolute -inset-1 bg-gradient-to-r from-brand-blue to-purple-600 rounded-xl blur opacity-20 group-hover:opacity-40 transition duration-1000"></div>
          
          <div class="relative bg-brand-dark border border-brand-border rounded-xl overflow-hidden shadow-2xl">
            
            <div class="bg-brand-surface border-b border-brand-border px-4 py-3 flex items-center justify-between">
               <div class="flex items-center gap-4">
                  <div class="w-32 h-3 bg-slate-700 rounded-full animate-pulse"></div>
               </div>
               <div class="flex gap-2">
                  <div class="w-8 h-8 rounded-full bg-slate-700"></div>
               </div>
            </div>

            <div class="flex">
               <div class="w-48 border-r border-brand-border p-4 hidden sm:block space-y-3">
                  <div class="h-2 w-20 bg-brand-blue/20 rounded"></div>
                  <div class="h-2 w-24 bg-slate-800 rounded"></div>
                  <div class="h-2 w-16 bg-slate-800 rounded"></div>
                  <div class="h-2 w-20 bg-slate-800 rounded"></div>
               </div>

               <div class="flex-1 p-6 bg-brand-dark/50">
                  <div class="grid grid-cols-3 gap-4 mb-6">
                     <div class="p-4 rounded-lg border border-brand-border bg-brand-surface">
                        <div class="text-xs text-slate-500 mb-1">Revenue (Live)</div>
                        <div class="text-lg font-bold text-white flex items-center gap-2">
                            $4.2M <span class="text-[10px] text-green-500 bg-green-500/10 px-1 rounded">+12%</span>
                        </div>
                     </div>
                     <div class="p-4 rounded-lg border border-brand-border bg-brand-surface">
                        <div class="text-xs text-slate-500 mb-1">Active Tenants</div>
                        <div class="text-lg font-bold text-brand-cyan">142</div>
                     </div>
                     <div class="p-4 rounded-lg border border-brand-border bg-brand-surface">
                        <div class="text-xs text-slate-500 mb-1">Server Load</div>
                        <div class="text-lg font-bold text-white">34%</div>
                     </div>
                  </div>

                  <div class="border border-brand-border rounded-lg overflow-hidden">
                     <div class="bg-brand-surface px-4 py-2 border-b border-brand-border grid grid-cols-4 gap-4 text-xs font-mono text-slate-500">
                        <span>TENANT_ID</span>
                        <span>CLIENT</span>
                        <span>STATUS</span>
                        <span>NODE</span>
                     </div>
                     <div class="p-2 space-y-2">
                        <div class="px-2 py-1 grid grid-cols-4 gap-4 text-xs text-slate-400 items-center">
                           <span>#ORG-992</span>
                           <span>Agencia Alpha</span>
                           <span class="text-brand-status-success bg-green-900/20 px-1 py-0.5 rounded w-fit">Active</span>
                           <span class="font-mono text-[10px] text-slate-600">us-east-1</span>
                        </div>
                        <div class="px-2 py-1 grid grid-cols-4 gap-4 text-xs text-slate-400 items-center">
                           <span>#ORG-993</span>
                           <span>Consultora Beta</span>
                           <span class="text-yellow-500 bg-yellow-900/20 px-1 py-0.5 rounded w-fit">Prov...</span>
                           <span class="font-mono text-[10px] text-slate-600">us-east-1</span>
                        </div>
                     </div>
                  </div>
               </div>
            </div>

          </div>
          
          <p class="text-center text-xs font-mono text-slate-600 mt-4">
            *Interfaz: Angular 18 (Signals) + Tailwind CSS | Backend: NestJS + Prisma ORM
          </p>
        </div>

        <div>
          <h2 class="text-3xl font-bold mb-2">Arquitectura para Escalar</h2>
          <p class="text-sm font-mono text-brand-cyan mb-8">Angular 18 + NestJS · TypeScript de Extremo a Extremo</p>
          
          <div class="space-y-8">
            <div class="flex gap-4">
              <div class="mt-1 bg-brand-blue/10 p-2 rounded-lg h-fit border border-brand-blue/20">
                <Users class="w-5 h-5 text-brand-blue" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Arquitectura Multi-tenant</h3>
                <p class="text-slate-400 text-sm">
                  Una sola plataforma para todos tus clientes, con los datos de cada uno completamente aislados. Cada empresa ve únicamente su información, como si tuviera su propio sistema privado.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="mt-1 bg-brand-cyan/10 p-2 rounded-lg h-fit border border-brand-cyan/20">
                <ShieldCheck class="w-5 h-5 text-brand-cyan" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">RBAC & Seguridad</h3>
                <p class="text-slate-400 text-sm">
                  Define quién puede ver qué y quién puede modificar qué. Control de permisos granular (Admin, Editor, Sólo lectura) con historial completo de acciones para auditorías y cumplimiento normativo.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="mt-1 bg-purple-500/10 p-2 rounded-lg h-fit border border-purple-500/20">
                <Zap class="w-5 h-5 text-purple-400" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Real-time con WebSockets</h3>
                <p class="text-slate-400 text-sm">
                  Olvida el botón "F5". Los pedidos, alertas y métricas aparecen en pantalla instantáneamente, sin recargar la página. Tu equipo ve los cambios en tiempo real desde cualquier dispositivo.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="mt-1 bg-green-500/10 p-2 rounded-lg h-fit border border-green-500/20">
                <Globe class="w-5 h-5 text-green-400" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">E2E Type Safety</h3>
                <p class="text-slate-400 text-sm">
                  Nuestro proceso elimina una categoría completa de errores antes de que lleguen a producción. El resultado: menos bugs críticos, menos tiempo perdido en soporte y entregas más predecibles.
                </p>
              </div>
            </div>
          </div>

          <div class="mt-10">
            <a href="#contacto" class="inline-flex items-center gap-2 bg-brand-blue text-white px-6 py-3 rounded-xl font-bold hover:bg-blue-600 transition-colors">
              Cotizar Plataforma <ArrowRight class="w-4 h-4" />
            </a>
          </div>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-6 border-t border-brand-border pt-20">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold mb-4">Ingeniería más allá del CRUD</h2>
            <p class="text-slate-400">No usamos plantillas administrativas genéricas. Construimos productos.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
            <div class="p-6 rounded-xl bg-brand-surface border border-brand-border hover:border-brand-cyan/30 transition-colors">
                <Globe class="w-8 h-8 text-slate-400 mb-4" />
                <h3 class="font-bold text-white mb-2">API First Design</h3>
                <p class="text-sm text-slate-400">Frontend y Backend desacoplados. Tu plataforma tendrá una API lista para integrarse con apps móviles o terceros.</p>
            </div>
            <div class="p-6 rounded-xl bg-brand-surface border border-brand-border hover:border-brand-cyan/30 transition-colors">
                <Lock class="w-8 h-8 text-slate-400 mb-4" />
                <h3 class="font-bold text-white mb-2">SSO & Auth</h3>
                <p class="text-sm text-slate-400">Integración con Google Workspace, Microsoft Azure AD u Okta para inicio de sesión corporativo.</p>
            </div>
            <div class="p-6 rounded-xl bg-brand-surface border border-brand-border hover:border-brand-cyan/30 transition-colors">
                <BarChart3 class="w-8 h-8 text-slate-400 mb-4" />
                <h3 class="font-bold text-white mb-2">Reportes Avanzados</h3>
                <p class="text-sm text-slate-400">Generación de PDFs, Excel y CSV masivos en segundo plano (Workers) sin bloquear la interfaz.</p>
            </div>
        </div>
      </div>

    </main>

    <FooterSection lang={lang} />
  </div>
</Layout>