---
import Layout from '../layouts/Layout.astro';
import { ArrowLeft, AlertTriangle, Terminal } from 'lucide-react';
---

<Layout title="404 // ROUTE_NOT_FOUND | BaseLogic" description="La ruta solicitada no existe en el servidor de BaseLogic.">

  <div class="min-h-screen flex flex-col items-center justify-center px-6 relative overflow-hidden">

    <!-- Grid pattern más pronunciado de fondo -->
    <div class="fixed inset-0 bg-grid-pattern opacity-40 pointer-events-none z-0"></div>

    <!-- Glow de error ambiental -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] bg-red-500/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute top-1/4 right-1/4 w-[200px] h-[200px] bg-amber-500/8 rounded-full blur-[80px] pointer-events-none"></div>

    <div class="relative z-10 max-w-2xl w-full">

      <!-- Barra de "ventana de terminal" -->
      <div class="rounded-t-xl bg-brand-surface border border-brand-border border-b-0 px-4 py-2.5 flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/30"></div>
        <div class="ml-3 flex items-center gap-2 text-slate-500">
          <Terminal class="w-3.5 h-3.5" />
          <span class="text-xs font-mono">baselogic-router · /dev/null</span>
        </div>
      </div>

      <!-- Cuerpo del terminal -->
      <div class="rounded-b-xl bg-brand-dark border border-brand-border p-8 md:p-12 shadow-2xl shadow-black/60">

        <!-- Líneas de "log" del sistema -->
        <div class="font-mono text-xs text-slate-600 space-y-1 mb-8">
          <p><span class="text-slate-700">$</span> GET {Astro.url.pathname} HTTP/1.1</p>
          <p><span class="text-slate-700">›</span> Resolving route... <span class="text-status-warning">FAILED</span></p>
          <p><span class="text-slate-700">›</span> Fallback handler invoked</p>
        </div>

        <!-- Código de estado -->
        <div class="flex items-start gap-4 mb-6">
          <div class="shrink-0 w-12 h-12 rounded-xl bg-red-500/10 border border-red-500/30 flex items-center justify-center">
            <AlertTriangle class="w-6 h-6 text-red-400" />
          </div>
          <div>
            <p class="text-xs font-mono text-red-400 uppercase tracking-[0.2em] mb-1">
              STATUS_CODE · 404
            </p>
            <h1 class="text-3xl md:text-5xl font-bold font-mono tracking-tight text-white leading-none">
              ROUTE_NOT
              <br />
              <span class="text-red-400">_FOUND</span>
            </h1>
          </div>
        </div>

        <!-- Mensaje -->
        <p class="text-slate-400 text-sm md:text-base leading-relaxed mb-2 font-mono border-l-2 border-brand-border pl-4">
          El servidor no pudo localizar el recurso solicitado.<br class="hidden md:block" />
          Es posible que la ruta haya sido reescrita o requiera<br class="hidden md:block" />
          credenciales de nivel superior.
        </p>

        <!-- Línea de prompt con cursor parpadeante -->
        <p class="font-mono text-xs text-slate-700 mb-10 flex items-center gap-1">
          <span>exit_code: 404</span>
          <span class="animate-pulse text-brand-cyan ml-1">_</span>
        </p>

        <!-- CTA -->
        <a
          href="/"
          class="inline-flex items-center gap-3 px-5 py-3 rounded-lg border border-brand-cyan/40 text-brand-cyan hover:bg-brand-cyan/10 hover:border-brand-cyan font-mono font-semibold text-sm transition-all hover:-translate-y-0.5 group"
        >
          <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
          &gt; Regresar_al_Sistema
        </a>

        <!-- Divider + branding mínimo -->
        <div class="mt-12 pt-6 border-t border-brand-border/40 flex items-center gap-2">
          <Terminal class="w-3.5 h-3.5 text-brand-cyan opacity-40" />
          <span class="font-mono text-xs text-slate-700">BaseLogic System © 2026</span>
        </div>

      </div>
    </div>

  </div>

</Layout>

<style>
  @keyframes scanline {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(100vh); }
  }
  .scanline {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(transparent, rgba(0, 229, 255, 0.04), transparent);
    animation: scanline 8s linear infinite;
    pointer-events: none;
    z-index: 5;
  }
</style>

<div class="scanline"></div>
