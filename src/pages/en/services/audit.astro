---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import FooterSection from '../../../components/FooterSection.astro';
import { Activity, Search, ShieldAlert, ArrowRight, Bug, FileSearch, Zap, Database } from 'lucide-react';

const lang = 'en';
---

<Layout title="Code Audit & Security | BaseLogic">
  
  <div class="fixed inset-0 bg-grid-pattern z-0 pointer-events-none opacity-30"></div>

  <div class="relative z-10">
    <Navbar lang={lang} translatedPath="/servicios/auditoria" />
    
    <main class="pt-32 pb-20">
      
      <div class="max-w-7xl mx-auto px-6 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-yellow-500/30 bg-yellow-500/10 text-yellow-500 text-xs font-mono mb-6">
          <Activity class="w-3 h-3" />
          Code Forensics
        </div>
        <h1 class="text-5xl md:text-7xl font-bold mb-6">
          Eliminate <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-300 to-red-500">
            Technical Debt.
          </span>
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl leading-relaxed">
          We analyze the "Black Box". We detect critical vulnerabilities, database bottlenecks, and spaghetti code before the system collapses in production.
        </p>
      </div>

      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-start mb-32">
        
        <div class="relative group order-last lg:order-last">
          <div class="absolute -inset-1 bg-gradient-to-r from-yellow-500 to-red-600 rounded-xl blur opacity-20 group-hover:opacity-40 transition duration-1000"></div>
          
          <div class="relative bg-brand-dark border border-brand-border rounded-xl overflow-hidden shadow-2xl">
            <div class="bg-brand-surface border-b border-brand-border px-4 py-2 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
              <div class="text-xs font-mono text-slate-500 ml-2">baselogic-audit · Angular/NestJS target</div>
            </div>

            <div class="p-6 font-mono text-xs md:text-sm overflow-x-auto leading-relaxed">
              <div class="text-slate-300">
                <span class="text-green-400">➜</span> <span class="text-blue-400">~</span> ./baselogic-audit --target=app --stack=angular,nestjs --deep<br><br>
                <span class="text-slate-500">[INFO] SAST + Runtime profiling started...</span><br>
                <span class="text-slate-500">[INFO] Analyzing 1,842 TypeScript files...</span><br>
                <br/>
                <span class="text-red-500 bg-red-500/10 px-1">WARN</span> <span class="text-white">Memory Leak · Unsubscribed RxJS Subject</span><br>
                <span class="text-slate-400 ml-4">↳ DashboardComponent.ts:88 — empty ngOnDestroy</span><br>
                <span class="text-slate-400 ml-4">↳ Impact: heap +120MB after 2h session</span><br>
                <br/>
                <span class="text-red-500 bg-red-500/10 px-1">WARN</span> <span class="text-white">N+1 Query · Prisma ORM (relations in loop)</span><br>
                <span class="text-slate-400 ml-4">↳ AssetService.ts:214 — findMany without include</span><br>
                <span class="text-slate-400 ml-4">↳ 14,000 queries/req → Latency: 4.8s</span><br>
                <br/>
                <span class="text-blue-400 bg-blue-500/10 px-1">INFO</span> <span class="text-white">Bottleneck Zone.js · Global Change Detection</span><br>
                <span class="text-slate-400 ml-4">↳ 38 components without OnPush strategy</span><br>
                <span class="text-slate-400 ml-4">↳ Recommendation: Migrate to Angular 18 Signals</span><br>
                <br/>
                <span class="text-green-500 bg-green-500/10 px-1">PASS</span> <span class="text-white">TypeScript strict mode · 0 type errors</span><br>
                <br/>
                <span class="text-brand-cyan">Generating Remediation Plan P1/P2/P3_</span><span class="animate-pulse">█</span>
              </div>
            </div>
          </div>

          <div class="flex gap-4 mt-6 justify-center">
             <div class="bg-brand-surface border border-brand-border px-4 py-2 rounded-lg flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
                <span class="text-xs font-mono text-slate-400">Critical Risks</span>
             </div>
             <div class="bg-brand-surface border border-brand-border px-4 py-2 rounded-lg flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-yellow-500"></div>
                <span class="text-xs font-mono text-slate-400">Performance</span>
             </div>
          </div>
        </div>

        <div>
          <h2 class="text-3xl font-bold mb-2">Precision Diagnosis</h2>
          <p class="text-sm font-mono text-yellow-500 mb-8">Specialists in Angular · NestJS · TypeScript</p>

          <div class="space-y-8">
            <div class="flex gap-4">
              <div class="mt-1 bg-red-500/10 p-2 rounded-lg h-fit border border-red-500/20">
                <ShieldAlert class="w-5 h-5 text-red-500" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Memory Leaks & RxJS</h3>
                <p class="text-slate-400 text-sm">
                  We detect Subjects without <code class="text-brand-cyan text-xs">unsubscribe</code>, hanging Observables in <code class="text-brand-cyan text-xs">ngOnDestroy</code>, and orphaned listeners that saturate the heap during long Angular sessions.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="mt-1 bg-yellow-500/10 p-2 rounded-lg h-fit border border-yellow-500/20">
                <Activity class="w-5 h-5 text-yellow-500" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Performance & Prisma ORM</h3>
                <p class="text-slate-400 text-sm">
                  We identify N+1 queries (relations loaded in a loop without <code class="text-brand-cyan text-xs">include</code>), missing PostgreSQL indexes, and Zone.js bottlenecks with a recommendation to migrate to Angular Signals.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="mt-1 bg-brand-blue/10 p-2 rounded-lg h-fit border border-brand-blue/20">
                <FileSearch class="w-5 h-5 text-brand-blue" />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Architecture & Technical Debt</h3>
                <p class="text-slate-400 text-sm">
                  We evaluate NestJS modules with high coupling, missing layer separation, and lack of strict TypeScript. If you inherited a "Frankenstein" project, we deliver a prioritized refactoring roadmap.
                </p>
              </div>
            </div>
          </div>

          <div class="mt-10">
            <a href="#contacto" class="inline-flex items-center gap-2 bg-white text-brand-dark px-6 py-3 rounded-xl font-bold hover:bg-slate-200 transition-colors">
              Request Express Audit <ArrowRight class="w-4 h-4" />
            </a>
          </div>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-6 border-t border-brand-border pt-20">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold mb-4">Forensic Methodology</h2>
            <p class="text-slate-400">We don't audit by "guessing". We use industry tools for objective data on TypeScript production applications.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
            <div class="p-6 rounded-xl bg-brand-surface border border-brand-border hover:border-yellow-500/30 transition-colors">
                <Zap class="w-8 h-8 text-slate-400 mb-4" />
                <h3 class="font-bold text-white mb-2">Load Testing (k6)</h3>
                <p class="text-sm text-slate-400">
                    We subject your NestJS API to simulated traffic (10k virtual users) to find the exact breaking point, including real-time WebSocket Gateways.
                </p>
            </div>
            
            <div class="p-6 rounded-xl bg-brand-surface border border-brand-border hover:border-yellow-500/30 transition-colors">
                <Bug class="w-8 h-8 text-slate-400 mb-4" />
                <h3 class="font-bold text-white mb-2">Static Analysis (SonarQube)</h3>
                <p class="text-sm text-slate-400">
                    Automated scanning of every TypeScript line to detect implicit <code class="text-yellow-400 text-xs">any</code>, high cyclomatic complexity, duplication, and dependencies with CVE vulnerabilities.
                </p>
            </div>
            
            <div class="p-6 rounded-xl bg-brand-surface border border-brand-border hover:border-yellow-500/30 transition-colors">
                <Database class="w-8 h-8 text-slate-400 mb-4" />
                <h3 class="font-bold text-white mb-2">Remediation Plan</h3>
                <p class="text-sm text-slate-400">
                    Not just bad news. We deliver a "Fix Roadmap" prioritized by impact and effort (P1, P2, P3) with corrected code examples for every finding.
                </p>
            </div>
        </div>
      </div>

    </main>

    <FooterSection lang={lang} />
  </div>
</Layout>