---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import FooterSection from '../../../components/FooterSection.astro';
import { Shield, Lock } from 'lucide-react';

const lang = 'en';
---

<Layout title="Privacy Policy | BaseLogic">
  <div class="fixed inset-0 bg-brand-dark z-0"></div>
  <div class="fixed inset-0 bg-grid-pattern z-0 pointer-events-none opacity-20"></div>

  <div class="relative z-10">
    <Navbar lang={lang} translatedPath="/legal/privacidad" />
    
    <main class="pt-32 pb-20 max-w-4xl mx-auto px-6">
      
      <div class="mb-12 border-b border-brand-border pb-8">
        <div class="flex items-center gap-2 text-brand-cyan mb-4">
          <Shield class="w-5 h-5" />
          <span class="font-mono text-sm">DATA PROTECTION</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-white">Privacy Policy</h1>
        <p class="text-slate-400 font-mono text-sm">Last updated: January 2026</p>
      </div>

      <div class="space-y-12 text-slate-300 leading-relaxed text-lg">
        
        <section>
          <h2 class="text-2xl font-bold text-white mb-4">1. Introduction</h2>
          <p>
            At <strong>BaseLogic</strong> ("we", "us", "our"), we respect your privacy and are committed to protecting the personal data you share with us. This policy describes how we collect, use, and protect your information when you visit our website or engage our engineering services.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-white mb-4">2. Information We Collect</h2>
          <p class="mb-4">We may collect the following types of information:</p>
          <ul class="list-disc pl-6 space-y-2 text-slate-400">
            <li><strong>Contact Information:</strong> Name, email address, phone number, and company name (when you request a demo or audit).</li>
            <li><strong>Technical Data:</strong> IP addresses, browser type, and on-site behavior data (to improve our UX).</li>
            <li><strong>Project Information:</strong> In the context of a contracted service, we may have access to server credentials, repositories, or databases. These are treated under strict Non-Disclosure Agreements (NDA).</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-white mb-4">3. Use of Information</h2>
          <p>We use your data exclusively to:</p>
          <ul class="list-disc pl-6 space-y-2 text-slate-400 mt-4">
            <li>Provide, operate, and maintain our software services.</li>
            <li>Process transactions and send related notices (invoices, confirmations).</li>
            <li>Respond to your comments, questions, and technical support requests.</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-white mb-4">4. Data Security</h2>
          <p>
            We implement Industry Standard security measures to protect your information. This includes SSL/TLS encryption in transit, encrypted storage at rest (where applicable), and strict access controls for our development team.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-white mb-4">5. Sharing Data with Third Parties</h2>
          <p>
            <strong>BaseLogic does not sell your data.</strong> We only share information with critical infrastructure providers necessary to operate (e.g., AWS, Vercel, Stripe) under secure data processing agreements.
          </p>
        </section>

        <section>
          <div class="bg-brand-surface border border-brand-border p-6 rounded-xl">
            <h3 class="flex items-center gap-2 font-bold text-white mb-2">
              <Lock class="w-4 h-4 text-brand-cyan" />
              Your Rights
            </h3>
            <p class="text-sm text-slate-400">
              You have the right to access, correct, or delete your personal data at any time. To exercise these rights, please contact us directly at <a href="mailto:legal@baselogic.dev" class="text-brand-cyan hover:underline">legal@baselogic.dev</a>.
            </p>
          </div>
        </section>

      </div>

    </main>

    <FooterSection lang={lang} />
  </div>
</Layout>