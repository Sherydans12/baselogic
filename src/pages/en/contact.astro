---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import FooterSection from '../../components/FooterSection.astro';
import ContactForm from '../../components/ContactForm';
import { Mail, MapPin } from 'lucide-react';
import { ui } from '../../i18n/ui';

const lang = 'en';
const t = ui[lang];
---

<Layout title="Contact | BaseLogic">
  <div class="fixed inset-0 bg-grid-pattern z-0 pointer-events-none opacity-30"></div>

  <div class="relative z-10">
    <Navbar lang={lang} translatedPath="/contacto" />
    
    <main class="pt-32 pb-20 max-w-7xl mx-auto px-6">
      
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
        
        <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-green-500/20 bg-green-500/5 text-green-500 text-xs font-mono mb-6">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                </span>
                Open for new projects
            </div>

            <h1 class="text-5xl font-bold mb-6">
                {t['contact.title']}
            </h1>
            <p class="text-xl text-slate-400 mb-12 leading-relaxed">
                {t['contact.subtitle']}
            </p>

            <div class="space-y-8 border-t border-brand-border pt-8">
                <div class="flex items-start gap-4">
                    <div class="p-3 bg-brand-surface rounded-lg border border-brand-border">
                        <Mail class="w-6 h-6 text-brand-cyan" />
                    </div>
                    <div>
                        <h3 class="text-white font-bold mb-1">{t['contact.info.email']}</h3>
                        <a href="mailto:hola@baselogic.dev" class="text-slate-400 hover:text-brand-cyan transition-colors">hola@baselogic.dev</a>
                    </div>
                </div>

                <div class="flex items-start gap-4">
                    <div class="p-3 bg-brand-surface rounded-lg border border-brand-border">
                        <MapPin class="w-6 h-6 text-brand-blue" />
                    </div>
                    <div>
                        <h3 class="text-white font-bold mb-1">{t['contact.info.location']}</h3>
                        <p class="text-slate-400">Santiago, Chile (Remote Worldwide)</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-brand-dark/50 p-6 md:p-8 rounded-2xl border border-brand-border backdrop-blur-sm shadow-2xl">
            <ContactForm client:load lang={lang} dict={t} />
        </div>

      </div>

    </main>

    <FooterSection lang={lang} />
  </div>
</Layout>