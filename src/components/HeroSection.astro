---
import { ArrowRight, Code2, Cpu, Database, Terminal, Server } from 'lucide-react';
import { ui } from '../i18n/ui';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = ui[lang];

const contactPath = lang === 'es' ? '/contacto' : '/en/contact';

const techStack = [
  { name: 'Angular', icon: Code2 },
  { name: 'NestJS', icon: Server },
  { name: 'TypeScript', icon: Terminal },
  { name: 'Prisma', icon: Database },
  { name: 'PostgreSQL', icon: Database },
];
---

<section class="relative pt-32 pb-16 md:pt-40 md:pb-24 overflow-hidden flex flex-col justify-center min-h-[85vh]">
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-brand-blue/20 rounded-full blur-[100px] -z-10 opacity-30 animate-pulse-slow"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 w-full">
    
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      
      <div class="max-w-2xl">
        
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-cyan/30 bg-brand-cyan/5 text-brand-cyan text-xs font-mono mb-6 cursor-default">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-cyan opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-cyan"></span>
          </span>
          {t['hero.badge']}
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-6 leading-tight">
          {t['hero.title.prefix']} <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan via-blue-400 to-brand-blue">
            {t['hero.title.highlight']}
          </span>
        </h1>

        <p class="text-lg text-slate-400 mb-8 leading-relaxed max-w-lg">
          {t['hero.subtitle']}
        </p>

        <div class="flex flex-wrap gap-4">
          <a href={contactPath} class="flex items-center justify-center gap-2 bg-brand-blue hover:bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold transition-all shadow-lg hover:shadow-brand-blue/25 hover:-translate-y-0.5 text-sm md:text-base">
            {t['hero.btn.primary']}
            <ArrowRight class="w-4 h-4" />
          </a>
          
          <a href="#eam" class="flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-semibold text-slate-300 border border-white/10 hover:bg-white/5 hover:border-white/20 transition-all hover:-translate-y-0.5 text-sm md:text-base">
            <ArrowRight class="w-4 h-4" />
            {t['hero.btn.secondary']}
          </a>
        </div>
      </div>

      <div class="relative hidden lg:block">
        <div class="relative w-full max-w-md mx-auto aspect-square animate-float">
            
            <div class="absolute inset-0 bg-brand-dark border border-brand-border rounded-xl shadow-2xl overflow-hidden transform rotate-[-2deg] hover:rotate-0 transition-transform duration-500 z-10">
                <div class="bg-brand-surface px-4 py-2 border-b border-brand-border flex gap-2">
                    <div class="w-3 h-3 rounded-full bg-red-500"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                    <div class="w-3 h-3 rounded-full bg-green-500"></div>
                </div>
                <div class="p-6 font-mono text-xs md:text-sm text-slate-300">
                    <p class="text-slate-500">// baselogic · asset-service.ts</p>
                    <br/>
                    <p><span class="text-purple-400">@Injectable</span><span class="text-slate-400">()</span></p>
                    <p><span class="text-blue-400">export class </span><span class="text-yellow-300">AssetService</span> <span class="text-slate-400">{</span></p>
                    <p class="pl-4"><span class="text-blue-400">async </span><span class="text-brand-cyan">getAvailability</span><span class="text-slate-400">(</span></p>
                    <p class="pl-8"><span class="text-white">assetId</span><span class="text-slate-400">: </span><span class="text-purple-400">string</span></p>
                    <p class="pl-4"><span class="text-slate-400">): </span><span class="text-purple-400">Promise</span><span class="text-slate-400">&lt;</span><span class="text-green-400">MtbfReport</span><span class="text-slate-400">&gt; {</span></p>
                    <p class="pl-8 text-slate-500">// CPP · Multi-tenant · SLA 99.9%</p>
                    <p class="pl-8"><span class="text-blue-400">return </span><span class="text-white">this</span><span class="text-slate-400">.</span><span class="text-brand-cyan">eam</span><span class="text-slate-400">.</span><span class="text-brand-blue">analyze</span><span class="text-slate-400">(assetId);</span></p>
                    <p class="pl-4 text-slate-400">}</p>
                    <p class="text-slate-400">}</p>
                    <br/>
                    <p class="animate-pulse text-brand-cyan">_</p>
                </div>
            </div>

            <div class="absolute -right-4 top-10 bg-brand-surface p-4 rounded-lg border border-brand-border shadow-xl animate-float-delayed z-20">
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-purple-500/20 rounded text-purple-400"><Database class="w-5 h-5"/></div>
                    <div>
                        <div class="text-[10px] text-slate-500 uppercase">Latency</div>
                        <div class="text-sm font-bold text-white">12ms</div>
                    </div>
                </div>
            </div>

            <div class="absolute -left-8 bottom-20 bg-brand-surface p-4 rounded-lg border border-brand-border shadow-xl animate-float z-20" style="animation-delay: -2s;">
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-green-500/20 rounded text-green-500"><Cpu class="w-5 h-5"/></div>
                    <div>
                        <div class="text-[10px] text-slate-500 uppercase">Uptime</div>
                        <div class="text-sm font-bold text-white">99.99%</div>
                    </div>
                </div>
            </div>

        </div>
      </div>

    </div>
  </div>

  <div class="absolute bottom-0 w-full border-t border-white/5 bg-brand-dark/80 backdrop-blur-sm py-4">
    <div class="relative w-full flex overflow-x-hidden group">
        <div class="animate-marquee flex gap-16 items-center whitespace-nowrap px-8">
            {[...techStack, ...techStack, ...techStack, ...techStack].map(({ name, icon: Icon }) => (
                <div class="flex items-center gap-2 text-slate-600 opacity-60 grayscale hover:grayscale-0 hover:opacity-100 hover:text-brand-cyan transition-all duration-300">
                    <Icon className="w-5 h-5" />
                    <span class="font-mono text-xs font-bold tracking-widest">{name.toUpperCase()}</span>
                </div>
            ))}
        </div>
        <div class="absolute top-0 animate-marquee2 flex gap-16 items-center whitespace-nowrap px-8">
            {[...techStack, ...techStack, ...techStack, ...techStack].map(({ name, icon: Icon }) => (
                <div class="flex items-center gap-2 text-slate-600 opacity-60 grayscale hover:grayscale-0 hover:opacity-100 hover:text-brand-cyan transition-all duration-300">
                    <Icon className="w-5 h-5" />
                    <span class="font-mono text-xs font-bold tracking-widest">{name.toUpperCase()}</span>
                </div>
            ))}
        </div>
    </div>
  </div>

</section>

<style>
  /* Animación Flotante Suave */
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  .animate-float-delayed {
    animation: float 7s ease-in-out infinite;
    animation-delay: 1s;
  }

  /* Animación Marquee */
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }
  .animate-marquee2 {
    animation: marquee2 40s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-100%); }
  }
  @keyframes marquee2 {
    0% { transform: translateX(100%); }
    100% { transform: translateX(0%); }
  }
</style>